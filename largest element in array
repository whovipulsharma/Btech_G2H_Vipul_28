// Online C compiler to run C program online
#include <stdio.h>

int main() {
    int n=0;
    printf("Enter the size of the matrix: ");
    scanf("%d",&n);
   int a[n];
   printf("Enter the elements:\n");
   for(int i=0;i<n;i++)
   {
       scanf("%d",&a[i]);
   }
   int max=a[0];
   printf("Entered Array:\n ");
    for(int i=0;i<n;i++)
   {
       printf("%d ",a[i]);
       if(a[i]>max)
       max=a[i];
   }
   printf("\nLargest element in array: %d",max);
    return 0;
}
