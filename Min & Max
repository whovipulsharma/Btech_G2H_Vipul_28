#include<stdio.h>
int main()
{   int n,s=0;
    printf("Enter the size: ");
    scanf("%d",&n);
    int a[n];
    printf("Enter elements in array:\n");
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int min=a[0];
    int max=a[0];
    printf("Entered Array:\n");
    for(int i=0;i<n;i++)
    {
        printf("%d ",a[i]);
    }
    for(int i=0;i<n;i++)
    {
        if(min>a[i])
        min=a[i];
        if(max<a[i])
        max=a[i];
    }
    printf("\nMaximum Element:%d\n",max);
    printf("Minimum Element:%d ",min);
}
