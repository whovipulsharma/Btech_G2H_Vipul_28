#include <stdio.h>

int main() {
    int r1,c1;
    
    printf("Enter the size of the matrix :\n ");
    scanf("%d%d",&r1,&c1);
   int a[r1][c1];
   printf("Enter the elements in matrix :\n");
   for(int i=0;i<r1;i++)
   {for(int j=0;j<c1;j++)
   {
       scanf("%d",&a[i][j]);
   }
   }
   printf("Entered Matrix:\n ");
   for(int i=0;i<r1;i++)
   {for(int j=0;j<c1;j++)
   {
       printf("%d ",a[i][j]);
   }printf("\n");
   }
   printf("Transpose of Matrix 2:\n ");
   for(int i=0;i<r1;i++)
   {for(int j=0;j<c1;j++)
   {
       printf("%d ",a[j][i]);
   }printf("\n");
   }
   
    return 0;
}
