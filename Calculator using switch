#include <stdio.h>
#include <ctype.h>
int main() {
    int a,b;
    char ch;
    printf("Enter two numbers a and b: \n ");
    scanf("%d%d",&a,&b);
    printf("Enter the operation to perform: \n ");
    scanf(" %c",&ch);
    switch(ch)
    {
        case '+':
        {
            printf("Sum:%d",a+b);
            break;
        }
        case '-':
        {
            printf("Difference:%d",a-b);
            break;
        }
        case '*':
        {
            printf("Product:%d",a*b);
            break;
        }
        case '/':
        {
            float d=b;
            printf("Division:%f",a/d);
            break;
        }
        case '%':
        {
            printf("Modulus:%d",a%b);
            break;
        }
        default:
        {
            printf("Invalid Operation");
        }
    }
    return 0;
}
