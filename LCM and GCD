#include <stdio.h>
int lcm(int n1,int n2)
    {
        int m=n1>n2?n1:n2;
    for(int i=1;i<=m;i++)
    {
       for(int j=1;j<=m;j++)
       {
           if((n1*i)==(n2*j))
           {
               return n1*i;
           }
       }
    }
        return 0;
    }
    int gcd(int n1,int n2){
        int g=1;
        int m=n1<n2?n1:n2;
    for(int i=1;i<=m;i++)
    {
        if((n1%i==0)&&(n2%i==0))
        {
            if(g<i)
            g=i;
        }
    }
        return g;
    }
int main() {
    int n1,n2;
    printf("Enter the numbers: \n");
    scanf("%d%d",&n1,&n2);
    printf("GCD: %d\n",gcd(n1,n2));
    printf("LCM: %d",lcm(n1,n2));
}
