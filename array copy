// Online C compiler to run C program online
#include <stdio.h>

int main() {
    int n=0;
    printf("Enter the size of the matrix: ");
    scanf("%d",&n);
   int a[n];
   printf("Enter the elements:\n");
   for(int i=0;i<n;i++)
   {
       scanf("%d",&a[i]);
   }
   int b[n];
    for(int i=0;i<=n;i++)
   {
       b[i]=a[i];
   }
   printf("Originl Array:\n ");
    for(int i=0;i<n;i++)
   {
       printf("%d ",a[i]);
   }
   printf("\nCopied Array:\n ");
    for(int i=0;i<n;i++)
   {
       printf("%d ",b[i]);
   }
    return 0;
}
