#include <stdio.h>
#include<string.h>
#include<math.h>
int dtb(int n)
{
    int s=0;
    int a[50];
    if(n==0)
    printf("0");
    else
    {
        while(n!=0)
    {
        int d=n%2;
        a[s]=d;
        n/=2;
        s++;
    } 
    for(int j=s-1;j>=0;j--)
    {
        printf("%d",a[j]);
    }
    }
    return 0;
}
int btd(char ch[])
{
    int x=0;
    int p=0;
    for(int i=strlen(ch)-1;i>=0;i--,p++)
    {
        if(ch[i]=='1')
        x+=pow(2,p);
    }
    printf("%d",x);
    return 0;
}
