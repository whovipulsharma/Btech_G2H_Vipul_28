
#include <stdio.h>

int main() {
    int n=0;
    printf("Enter the size of the matrix: ");
    scanf("%d",&n);
   int a[n];
   printf("Enter the elements:\n");
   for(int i=0;i<n;i++)
   {
       scanf("%d",&a[i]);
   }
   printf("Entered Array:\n ");
    for(int i=0;i<n;i++)
   {
       printf(" %d",a[i]);
   }
   for(int i=0;i<n;i++){
       for(int j=0;j<=n-i-1;j++)
       {
           if(a[j]>a[j+1])
           {
               int t=a[j];
               a[j]=a[j+1];
               a[j+1]=t;
           }
       }
   }
   printf("\nSorted Array:\n ");
    for(int i=0;i<n;i++)
   {
       printf(" %d",a[i]);
   }
    return 0;
}
