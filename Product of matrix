#include <stdio.h>

int main() {
    int r1,c1,r2,c2;
    
    printf("Enter the size of the matrix 1:\n ");
    scanf("%d%d",&r1,&c1);
    printf("Enter the size of the matrix 2:\n ");
    scanf("%d%d",&r2,&c2);
   int a[r1][c1];
   int b[r2][c2];
   int c[r1][c2];
   printf("Enter the elements in matrix 1:\n");
   for(int i=0;i<r1;i++)
   {for(int j=0;j<c1;j++)
   {
       scanf("%d",&a[i][j]);
   }
   }
   printf("Enter the elements in matrix 2:\n");
   for(int i=0;i<r2;i++)
   {for(int j=0;j<c2;j++)
   {
       scanf("%d",&b[i][j]);
   }
   }
   printf("Entered Matrix 1:\n ");
   for(int i=0;i<r1;i++)
   {for(int j=0;j<c1;j++)
   {
       printf("%d ",a[i][j]);
   }printf("\n");
   }
   printf("Entered Matrix 2:\n ");
   for(int i=0;i<r2;i++)
   {for(int j=0;j<c2;j++)
   {
       printf("%d ",b[i][j]);
   }printf("\n");
   }
   for(int i=0;i<r1;i++)
   {for(int j=0;j<c2;j++)
   {
       c[i][j]=0;
       for(int k=0;k<c1;k++)
       {
           c[i][j]+=a[i][k]*b[k][j];
       }
   }
   }
   printf("Product Matrix :\n ");
   for(int i=0;i<r2;i++)
   {for(int j=0;j<c2;j++)
   {
       printf("%d ",c[i][j]);
   }printf("\n");
   }
    return 0;
}
