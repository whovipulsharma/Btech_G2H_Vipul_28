#include <stdio.h>

int main() {
    int r,sl=0,sr=0;
    
    printf("Enter the size of the matrix :\n ");
    scanf("%d",&r);
   int a[r][r];
   printf("Enter the elements in matrix :\n");
   for(int i=0;i<r;i++)
   {for(int j=0;j<r;j++)
   {
       scanf("%d",&a[i][j]);
   }
   }
   printf("Entered Matrix:\n ");
   for(int i=0;i<r;i++)
   {for(int j=0;j<r;j++)
   {if(i==j)
   sr+=a[i][j];
   if((i+j)==r-1)
   sl+=a[i][j];
       printf("%d ",a[i][j]);
   }printf("\n");
   }
   printf("Sum of right diagonal: %d\nSum of left diagonal: %d",sr,sl);
   
    return 0;
}
