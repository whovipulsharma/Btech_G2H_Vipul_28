// Online C compiler to run C program online
#include <stdio.h>

int main() {
    int a,b,c;
    printf("Enter the sides:\n");
    scanf("%d%d%d",&a,&b,&c);
    if((a+b>c)||(b+c>a)||(a+c>b))
    {
        if((a==b)&&(b==c))
        printf("It's a valid equilateral triangle");
        else if((a!=b)&&(b!=c))
        printf("It's a valid scalene triangle");
        else
        printf("It's a valid isoceles triangle");
    }
    else
    printf("It's an invalid triangle ");
    return 0;
}
