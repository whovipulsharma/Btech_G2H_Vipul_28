#include <stdio.h>

int main() {
    int r,c1,sr=0;
    
    printf("Enter the size of the matrix :\n ");
    scanf("%d%d",&r,&c1);
   int a[r][r];
   printf("Enter the elements in matrix :\n");
   for(int i=0;i<r;i++)
   {for(int j=0;j<c1;j++)
   {
       scanf("%d",&a[i][j]);
   }
   }
   printf("Entered Matrix:\n ");
   for(int i=0;i<r;i++)
   {for(int j=0;j<c1;j++)
   {
       printf("%d ",a[i][j]);
   }printf("\n");
   }
   

   for(int i=0;i<r;i++)
   {for(int j=0;j<c1;j++)
   {
       sr+=a[i][j];
   }
   printf("Sum of row %d: %d\n",i+1,sr);
   sr=0;
   }
   
  for(int i=0;i<c1;i++)
   {for(int j=0;j<r;j++)
   {
       sr+=a[j][i];
   }
   printf("Sum of column %d: %d\n",i+1,sr);
   sr=0;
   }
    return 0;
}
