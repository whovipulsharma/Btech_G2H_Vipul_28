#include<stdio.h>
int main()
{   int n,s=0;
    printf("Enter the size: ");
    scanf("%d",&n);
    int a[n];
    printf("Enter the elements:\n ");
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    printf("Entered array the elements:\n ");
    for(int i=0;i<n;i++)
    {
        printf("%d ",a[i]);
    }
    for(int i=0;i<n;i++)
    {
        s+=a[i];
    }
    printf("\nSum of the elements:%d ",s);
}
