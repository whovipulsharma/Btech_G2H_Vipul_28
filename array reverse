
#include <stdio.h>

int main() {
    int n=0;
    printf("Enter the size of the matrix: ");
    scanf("%d",&n);
   int a[n];
   printf("Enter the elements:\n");
   for(int i=0;i<n;i++)
   {
       scanf("%d",&a[i]);
   }
   int j=0;
   int b[n];
    for(int i=n-1;i>=0;i--)
   {
       b[j]=a[i];
       j++;
   }
   printf("Reversed array:\n ");
    for(int i=0;i<n;i++)
   {
       printf("%d ",b[i]);
   }
    return 0;
}
